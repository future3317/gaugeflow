  "selection": {
    "primary": "minimum EMA validation macro loss",
    "test_usage": "exactly once after best-step selection",
    "maximum_updates": 8000,
    "validation_interval": 500,
    "early_stopping_patience_evaluations": 6,
    "minimum_absolute_improvement": 0.002
  },
  "boundaries": [
    "The D0 response probe was rejected and is not tuned in formal training.",
    "Stage D is a clean-structure response predictor and never consumes generator rollouts.",
