{
  "protocol": "stage_d_response_training_v1",
  "seed": 5731,
  "steps": 8000,
  "batch_size": 32,
  "precision": "bf16",
  "backbone_learning_rate": 1e-5,
  "head_learning_rate": 3e-4,
  "weight_decay": 1e-4,
  "gradient_clip": 1.0,
  "ema_decay": 0.999,
  "warmup_steps": 200,
  "checkpoint_every": 500,
  "validation_every": 500,
  "early_stopping_patience": 6,
